# ─────────────────────────────────────────────────────────────────────────────
# GetAJob — Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.  Never commit the real
# .env to version control — it is already in .gitignore.
#
#   cp env.template .env
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
GETAJOB_ENVIRONMENT=development
GETAJOB_DEBUG=true
GETAJOB_LOG_FORMAT=console

# ── PostgreSQL ───────────────────────────────────────────────────────────────
GETAJOB_DATABASE__HOST=localhost
GETAJOB_DATABASE__PORT=5432
GETAJOB_DATABASE__DATABASE=getajob
GETAJOB_DATABASE__USER=getajob
GETAJOB_DATABASE__PASSWORD=change_me_in_production
GETAJOB_DATABASE__MIN_CONNECTIONS=2
GETAJOB_DATABASE__MAX_CONNECTIONS=10

# ── LLM (Anthropic Claude) ──────────────────────────────────────────────────
GETAJOB_LLM__PROVIDER=anthropic
GETAJOB_LLM__API_KEY=sk-ant-xxxxxxxxxxxxx
GETAJOB_LLM__MODEL=claude-sonnet-4-6
GETAJOB_LLM__MAX_TOKENS=4096
GETAJOB_LLM__TEMPERATURE=0.7
GETAJOB_LLM__TIMEOUT_SECONDS=120

# ── Redis ────────────────────────────────────────────────────────────────────
GETAJOB_REDIS__HOST=localhost
GETAJOB_REDIS__PORT=6379
GETAJOB_REDIS__DB=0
# GETAJOB_REDIS__PASSWORD=

# ── Security / Encryption ───────────────────────────────────────────────────
# Generate a 64-char hex key (32 bytes):  python3 -c "import os; print(os.urandom(32).hex())"
GETAJOB_SECURITY__ENCRYPTION_KEY=
# Generate a 32-char hex salt (16 bytes):  python3 -c "import os; print(os.urandom(16).hex())"
GETAJOB_SECURITY__ENCRYPTION_SALT=
GETAJOB_SECURITY__TOKENIZER_SALT=

# ── Browser Automation ──────────────────────────────────────────────────────
GETAJOB_BROWSER__HEADLESS=true
GETAJOB_BROWSER__VIEWPORT_WIDTH=1920
GETAJOB_BROWSER__VIEWPORT_HEIGHT=1080
GETAJOB_BROWSER__LOCALE=en-US
# GETAJOB_BROWSER__PROXY=http://user:pass@proxy.example.com:8080
GETAJOB_BROWSER__SLOW_MO_MS=50
GETAJOB_BROWSER__NAVIGATION_TIMEOUT_SECONDS=30

# ── Job Discovery ────────────────────────────────────────────────────────────
GETAJOB_JOB_DISCOVERY__MAX_APPLICATIONS_PER_DAY=50
